            "dataType": "int64",
            "sourceColumn": "dias_vs_agendado",
            "summarizeBy": "none"
          },
          {
            "name": "tempo_ciclo_dias",
            "dataType": "int64",
            "sourceColumn": "tempo_ciclo_dias",
            "summarizeBy": "none"
          },
          {
            "name": "reward",
            "dataType": "decimal",
            "sourceColumn": "reward",
            "summarizeBy": "none"
          },
          {
