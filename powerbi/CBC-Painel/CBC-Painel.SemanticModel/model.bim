{
  "name": "CBC-Painel",
  "compatibilityLevel": 1550,
  "model": {
    "culture": "pt-BR",
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "sourceQueryCulture": "pt-BR",
    "annotations": [
      {
        "name": "PBI_TimeIntelligenceEnabled",
        "value": "0"
      }
    ],
    "tables": [
      {
        "name": "Produtividade",
        "columns": [
          {
            "name": "tarefa_id",
            "dataType": "int64",
            "sourceColumn": "tarefa_id",
            "summarizeBy": "none"
          },
          {
            "name": "tarefa",
            "dataType": "string",
            "sourceColumn": "tarefa",
            "summarizeBy": "none"
          },
          {
