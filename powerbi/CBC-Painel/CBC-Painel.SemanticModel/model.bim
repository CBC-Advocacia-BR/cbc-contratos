            "name": "retrabalho",
            "dataType": "boolean",
            "sourceColumn": "retrabalho",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "Produtividade",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = PostgreSQL.Database(\"aws-1-sa-east-1.pooler.supabase.com:5432\", \"postgres\"),\n    dados = Source{[Schema=\"public\",Item=\"vw_bi_produtividade\"]}[Data]\nin\n    dados"
            }
          }
        ],
        "measures": [
          {
            "name": "Concluídas",
            "expression": "CALCULATE(COUNTROWS(Produtividade), Produtividade[categoria] <> \"sistema\")",
            "formatString": "#,0"
          },
          {
            "name": "Tempo Mediano (dias)",
            "expression": "CALCULATE(MEDIAN(Produtividade[tempo_ciclo_dias]), Produtividade[categoria] = \"ciclo\")",
            "formatString": "0.0"
          },
          {
            "name": "Tempo Médio (dias)",
            "expression": "CALCULATE(AVERAGE(Produtividade[tempo_ciclo_dias]), Produtividade[categoria] = \"ciclo\")",
            "formatString": "0.0"
          },
          {
            "name": "% Em Dia",
            "expression": "DIVIDE(CALCULATE([Concluídas], Produtividade[dias_vs_agendado] <= 0), CALCULATE([Concluídas], NOT ISBLANK(Produtividade[dias_vs_agendado])))",
            "formatString": "0.0%"
          },
          {
            "name": "Qtde Retrabalho",
            "expression": "CALCULATE([Concluídas], Produtividade[retrabalho] = TRUE())",
            "formatString": "#,0"
          },
          {
            "name": "Taxa Retrabalho Inicial",
            "expression": "DIVIDE(CALCULATE([Concluídas], Produtividade[tarefa] = \"REFAZER INICIAL\"), CALCULATE([Concluídas], Produtividade[tarefa] = \"FAZER INICIAL\"))",
            "formatString": "0.0%"
          }
        ]
      },
