              "type": "m",
              "expression": "let\n    Source = PostgreSQL.Database(\"aws-1-sa-east-1.pooler.supabase.com:5432\", \"postgres\"),\n    dados = Source{[Schema=\"public\",Item=\"vw_bi_distribuicao\"]}[Data]\nin\n    dados"
            }
          }
        ],
        "measures": [
          {
            "name": "Distribuídos",
            "expression": "CALCULATE(COUNTROWS(Distribuicao), Distribuicao[distribuido] = TRUE(), Distribuicao[cadastro_retroativo] = FALSE())",
            "formatString": "#,0"
          },
          {
            "name": "Dias até Distribuir (mediana)",
            "expression": "CALCULATE(MEDIAN(Distribuicao[dias_ate_distribuir]), Distribuicao[cadastro_retroativo] = FALSE())",
            "formatString": "0.0"
          },
          {
            "name": "Aguardando Distribuição",
            "expression": "CALCULATE(COUNTROWS(Distribuicao), Distribuicao[distribuido] = FALSE(), ALL(Calendario))",
            "formatString": "#,0"
          },
          {
            "name": "Dias Aguardando",
            "expression": "CALCULATE(MAX(Distribuicao[dias_aguardando]), Distribuicao[distribuido] = FALSE())",
            "formatString": "#,0"
          }
        ]
