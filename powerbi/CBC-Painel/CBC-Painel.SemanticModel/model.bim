        "partitions": [
          {
            "name": "CargaAtual",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = PostgreSQL.Database(\"aws-1-sa-east-1.pooler.supabase.com:5432\", \"postgres\"),\n    dados = Source{[Schema=\"public\",Item=\"vw_bi_carga_atual\"]}[Data]\nin\n    dados"
            }
          }
        ],
        "measures": [
          {
            "name": "Tarefas Abertas",
            "expression": "COUNTROWS(CargaAtual)",
            "formatString": "#,0"
          },
          {
            "name": "Vencidas",
            "expression": "CALCULATE(COUNTROWS(CargaAtual), CargaAtual[situacao_agenda] = \"vencida\")",
            "formatString": "#,0"
          },
          {
            "name": "Tarefas Vencidas",
            "expression": "CALCULATE(DISTINCTCOUNT(CargaAtual[tarefa_id]), CargaAtual[situacao_agenda] = \"vencida\")",
            "formatString": "#,0"
          }
        ]
      },
