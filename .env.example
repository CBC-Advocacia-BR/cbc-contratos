# =====================================================
# CBC Contratos — variáveis existentes
# =====================================================

# AWS S3 Backup (optional - backups will still save locally without these)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=cbc-contratos-backups

# Note: Enable versioning on the S3 bucket for automatic version history

# =====================================================
# CBC TESES — novas variáveis
# =====================================================

# --- Client (Vite) — expostas ao browser (prefixo VITE_) ---
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Server (privadas) ---
# Chave de serviço do Supabase (usada apenas no backend)
SUPABASE_SERVICE_ROLE_KEY=

# Advbox — token Bearer (NUNCA exponha no client)
ADVBOX_API_URL=https://app.advbox.com.br/api/v1
ADVBOX_BEARER_TOKEN=

# DataJud (CNJ)
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=

# Google OAuth (configurado no Supabase Dashboard → Auth Providers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
